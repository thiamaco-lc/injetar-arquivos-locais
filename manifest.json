{
  "manifest_version": 3,
  "name": "Injetar Arquivos Locais",
  "version": "2.0",
  "description": "Injeta arquivos CSS, JS e HTML (por URL ou do disco) na página, com auto-detecção de tipo e reinjeção automática.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.css", "*.js", "*.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "Injetar Arquivos"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
